# Доставка: расчёт в /api/calculate-delivery и на сервере при заказе (delivery-pricing.ts).
# Отдельные ключи не нужны — это MVP (курьер Мск/Реутов, ПВЗ-заглушка, почта). Реальный API СДЭК — отдельная интеграция.

# Supabase (после применения миграции supabase/migrations/20260419000000_shop_tables.sql)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Только сервер: создание заказов и позиций (не публикуйте в клиент)
SUPABASE_SERVICE_ROLE_KEY=

# Яндекс.Карты — выбор пункта выдачи на чекауте (https://developer.tech.yandex.ru/)
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=

# Email (Resend): письма покупателю при заказе и смене статуса
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Telegram: уведомление администратору о новом заказе
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# Секрет для PATCH /api/orders/[id]/status (смена статуса + email покупателю)
ORDER_ADMIN_SECRET=
